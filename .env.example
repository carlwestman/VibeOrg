# VibeOrg Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required for scheduled agent tasks (headless Claude Code invocations)
# ANTHROPIC_API_KEY=sk-ant-...

# Add API keys for configured data sources and integrations below.
# These will be populated during onboarding (/init).

# Claude Code Channels (optional — for remote access via messaging)
# Set up via /init onboarding or manually via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# Your Telegram chat ID (obtained during channel pairing)
# Used by the scheduler to send completion/failure notifications
# TELEGRAM_CHAT_ID=
